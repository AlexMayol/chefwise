{
  "name": "chefwise",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@rn-primitives/portal": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.11",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-web-browser": "~56.0.5",
    "i18next": "^26.3.2",
    "jszip": "^3.10.1",
    "lucide-react-native": "^1.21.0",
    "nativewind": "^5.0.0-preview.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.80.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-css": "^3.0.7",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "expo-mcp": "~0.2.1",
    "jest-expo": "^56.0.5",
    "postcss": "^8.5.15",
    "react-test-renderer": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --watchAll=false",
    "typecheck": "tsc --noEmit",
    "seed:db": "node --experimental-sqlite --experimental-strip-types scripts/seed-db.ts",
    "web": "expo start --web",
    "test:android": "eas build --platform android --profile development"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.ts"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts",
      "**/tests/**/*.test.tsx"
    ],
    "moduleNameMapper": {
      "^nativewind/jsx-runtime$": "react/jsx-runtime"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native|expo(nent)?|@expo(nent)?/.*|expo-.*|@expo/.*|@react-navigation/.*|nativewind|react-native-css|@rn-primitives/.*)/)"
    ]
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "private": true
}
